<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.gui.controllers.FeedController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: #ffffff; -fx-border-color: #dddddd; -fx-border-width: 0 0 1 0;">
            <padding>
                <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
            </padding>
            <children>
                <Label text="NetworkApp" textFill="#2c3e50">
                    <font>
                        <Font name="System Bold" size="20.0" />
                    </font>
                </Label>
                <Region prefWidth="20.0" />
                <TextField fx:id="searchField" prefWidth="300.0" promptText="Search by username..." />
                <Button onAction="#handleSearch" text="Search" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="welcomeLabel" text="Welcome, User!" />
                <Button onAction="#handleLogout" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="Logout" />
            </children>
        </HBox>
    </top>

    <left>
        <VBox prefWidth="250.0" spacing="15.0" style="-fx-background-color: #f9f9f9; -fx-border-color: #dddddd; -fx-border-width: 0 1 0 0;">
            <padding>
                <Insets bottom="20.0" left="15.0" right="15.0" top="20.0" />
            </padding>
            <children>
                <Label text="New Post">
                    <font>
                        <Font name="System Bold" size="16.0" />
                    </font>
                </Label>
                <TextArea fx:id="postTextArea" prefHeight="150.0" promptText="What's on your mind?" wrapText="true" />
                <Button maxWidth="Infinity" onAction="#handleCreatePost" style="-fx-background-color: #3498db; -fx-text-fill: white;" text="Publish Post" />

                <Separator prefWidth="200.0" />

                <Label text="Menu" textFill="#7f8c8d" />
                <Button maxWidth="Infinity" text="My Profile"/>
                <Button maxWidth="Infinity" text="Settings"/>
            </children>
        </VBox>
    </left>

    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE">
            <tabs>
                <Tab text="Global Feed">
                    <content>
                        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
                            <content>
                                <VBox fx:id="postsContainer" spacing="15.0">
                                    <padding>
                                        <Insets bottom="20.0" left="30.0" right="30.0" top="20.0" />
                                    </padding>
                                </VBox>
                            </content>
                        </ScrollPane>
                    </content>
                </Tab>

                <Tab text="Leaderboard">
                    <content>
                        <VBox alignment="TOP_CENTER" spacing="20.0">
                            <padding>
                                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                            </padding>
                            <children>
                                <HBox alignment="CENTER" spacing="15.0">
                                    <children>
                                        <Label text="Show Top:">
                                            <font><Font name="System Bold" size="14.0" /></font>
                                        </Label>
                                        <ComboBox fx:id="leaderboardTypeCombo" onAction="#handleLeaderboardTypeChange" prefWidth="180.0" />
                                    </children>
                                </HBox>

                                <TableView fx:id="leaderboardTable" prefHeight="450.0" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="rankColumn" prefWidth="50.0" text="#" />
                                        <TableColumn fx:id="userColumn" prefWidth="250.0" text="User / Post Content" />
                                        <TableColumn fx:id="likesColumn" prefWidth="120.0" text="Likes" />
                                    </columns>
                                </TableView>
                            </children>
                        </VBox>
                    </content>
                </Tab>
            </tabs>
        </TabPane>
    </center>

</BorderPane>